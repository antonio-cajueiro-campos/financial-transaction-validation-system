        <mxCell id="YYMyKXkz91Ap7fzcnGvL-356" parent="YYMyKXkz91Ap7fzcnGvL-269" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" value="&lt;div&gt;Mensagerias:&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Kafka / MSK&lt;/div&gt;&lt;div&gt;RabbitMQ / SQS&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="159.33" x="3270" y="1471.5" as="geometry" />
        </mxCell>
        <mxCell id="YYMyKXkz91Ap7fzcnGvL-479" edge="1" parent="YYMyKXkz91Ap7fzcnGvL-269" source="YYMyKXkz91Ap7fzcnGvL-357" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;dashPattern=8 4 1 4;" target="YYMyKXkz91Ap7fzcnGvL-185">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="YYMyKXkz91Ap7fzcnGvL-513" edge="1" parent="YYMyKXkz91Ap7fzcnGvL-269" source="YYMyKXkz91Ap7fzcnGvL-357" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;dashPattern=8 4 1 4;" target="YYMyKXkz91Ap7fzcnGvL-512">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="YYMyKXkz91Ap7fzcnGvL-357" parent="YYMyKXkz91Ap7fzcnGvL-269" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4 1 4;" value="Nessa etapa, os EKS consomem os eventos de transação,&lt;div&gt;com a key do evento sendo o id do cliente para termos ordenação e&amp;nbsp;consistência no consumo dos eventos.&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Para o fluxo ter idempotência, o EKS faria uma validação pelo&lt;/div&gt;&lt;div&gt;Id único da transação&lt;br&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;O EKS usaria KEDA para escalar por demanda de eventos,&lt;/div&gt;&lt;div&gt;ou HPA por consumo de recursos.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Ele também consultaria a base de saldo, limites&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;parametrizados&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;por produto e persistiria as transações&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;para auditoria e&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;notificaria o produto&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;em caso de&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;aprovação/reprovação&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;de uma transação&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;O consumer também contaria com retry/ack e fila de DLQ para&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;reprocessamento de eventos que falharam&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="406" x="1407" y="150" as="geometry" />
        </mxCell>
        <mxCell id="YYMyKXkz91Ap7fzcnGvL-482" edge="1" parent="YYMyKXkz91Ap7fzcnGvL-269" source="YYMyKXkz91Ap7fzcnGvL-358" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;dashPattern=8 4 1 4;" target="YYMyKXkz91Ap7fzcnGvL-285">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="2250" y="520" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="YYMyKXkz91Ap7fzcnGvL-508" edge="1" parent="YYMyKXkz91Ap7fzcnGvL-269" source="YYMyKXkz91Ap7fzcnGvL-358" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;dashPattern=8 4 1 4;" target="YYMyKXkz91Ap7fzcnGvL-360">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="2250" y="470" />
              <mxPoint x="2470" y="470" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="YYMyKXkz91Ap7fzcnGvL-358" parent="YYMyKXkz91Ap7fzcnGvL-269" style="whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4 1 4;" value="&lt;div&gt;Para persistir os dados transacionais, decidi escolher o DynamoDB,&lt;/div&gt;&lt;div&gt;por ser uma base altamente  escalável, performática e fortemente&lt;/div&gt;&lt;div&gt;consistente se configurado a leitura corretamente.&lt;/div&gt;&lt;div&gt;Com isso iria&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;segurar a demanda de até 4k TPS&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;No DynamoDB eu utilizaria o Pattern de Single Table Design para maximizar performance e resolver as consultas em baixa latência&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Com operações transacionais (ACID), em casos onde pode ter&lt;/div&gt;&lt;div&gt;operações&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;em saldo simultâneas,&lt;/span&gt;&lt;/div&gt;&lt;div&gt;eu usaria Conditional Write para evitar Race Condition e&lt;/div&gt;&lt;div&gt;TransactWrite para garantir Atomicidade se alguma operação&lt;/div&gt;&lt;div&gt;falhar, fazendo o rollback do processo&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Caso tenha necessidade de consultas sem ter relação com o cliente,&lt;/div&gt;&lt;div&gt;criaria uma GSI, por exemplo, buscar todas as transações pendentes do sistema&amp;nbsp;STATUS#PENDENTE&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="438" x="2032" y="110" as="geometry" />
        </mxCell>
        <mxCell id="YYMyKXkz91Ap7fzcnGvL-517" edge="1" parent="YYMyKXkz91Ap7fzcnGvL-269" source="YYMyKXkz91Ap7fzcnGvL-359" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;dashPattern=8 4 1 4;" target="YYMyKXkz91Ap7fzcnGvL-207">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="YYMyKXkz91Ap7fzcnGvL-359" parent="YYMyKXkz91Ap7fzcnGvL-269" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4 1 4;" value="O Product System é responsável por enviar as requests&lt;div&gt;de transação, e analisar aprovações e reprovações feitas&lt;/div&gt;&lt;div&gt;pelo usuário&lt;/div&gt;" vertex="1">
          <mxGeometry height="110" width="360" x="110" y="390" as="geometry" />
        </mxCell>
        <mxCell id="YYMyKXkz91Ap7fzcnGvL-360" parent="YYMyKXkz91Ap7fzcnGvL-269" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;align=left;dashPattern=8 4 1 4;" value="&amp;nbsp; {&lt;br&gt;&amp;nbsp; &amp;nbsp; &quot;saldoDisponivel&quot;: &lt;span class=&quot;ͼq&quot;&gt;1000&lt;/span&gt;,&lt;br&gt;&amp;nbsp; &amp;nbsp; &quot;saldoReservado&quot;: &lt;span class=&quot;ͼq&quot;&gt;200&lt;/span&gt;&lt;br&gt;&amp;nbsp; }" vertex="1">
          <mxGeometry height="90" width="160" x="2390" y="520" as="geometry" />
        </mxCell>
        <mxCell id="YYMyKXkz91Ap7fzcnGvL-484" edge="1" parent="YYMyKXkz91Ap7fzcnGvL-269" source="YYMyKXkz91Ap7fzcnGvL-361" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;dashPattern=8 4 1 4;" target="YYMyKXkz91Ap7fzcnGvL-189">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="YYMyKXkz91Ap7fzcnGvL-361" parent="YYMyKXkz91Ap7fzcnGvL-269" style="rounded=0;whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4 1 4;" value="A API Rest faz um consumo&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;de requests de transação,&lt;/span&gt;&lt;div&gt;&lt;div&gt;com IDs dos clientes, valores, limite por&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;produto etc&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;e publica num tópico Kafka para ser processado.&lt;/span&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;O EKS também receberia requests do BFF para envio&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;de aprovações/reprovações de transação e&lt;/div&gt;&lt;div&gt;requests para consulta de saldo&lt;/div&gt;&lt;div&gt;e atualização de parametros de limite&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;O EKS usaria HPA ou se recebesse via eventos,&lt;/div&gt;&lt;div&gt;poderia ser um KEDA para scale on demanda&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="320" x="590" y="150" as="geometry" />
        </mxCell>
