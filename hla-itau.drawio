        <mxCell id="YYMyKXkz91Ap7fzcnGvL-469" parent="YYMyKXkz91Ap7fzcnGvL-269" style="whiteSpace=wrap;html=1;dashed=1;dashPattern=8 4 1 4;" value="&lt;div&gt;Para possibilitar a geração de relatórios e auditorias/BI,&lt;/div&gt;&lt;div&gt;eu utilizaria uma arquitetura OLAP,&amp;nbsp; transferindo os registros de dados transacionais&lt;/div&gt;&lt;div&gt;do OLTP para uma base fria (S3/BlobStorage) e Athena pra&lt;/div&gt;&lt;div&gt;consulta posterior para geração de BIs&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Vantagens de ter um sistema OLAP separado seria não impactar o&lt;/div&gt;&lt;div&gt;sistema transacional com as consultas e processamentos&lt;/div&gt;&lt;div&gt;pesados de dados, dentre outras vantagens também entra baixo custo&lt;/div&gt;&lt;div&gt;de operação, pois fazer scan num modelo nao otimizado pra scan teria um custo por leitura maior (RCU) do que num Blob Storage, além de i&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;solamento e flexibilidade..&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;TradeOffs:&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp;Complexidade, latência e Consistência&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="480" x="2665.67" y="150" as="geometry" />
        </mxCell>
        <mxCell id="YYMyKXkz91Ap7fzcnGvL-486" edge="1" parent="YYMyKXkz91Ap7fzcnGvL-269" source="YYMyKXkz91Ap7fzcnGvL-473" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=1;entryDx=0;entryDy=0;dashed=1;dashPattern=8 4 1 4;" target="YYMyKXkz91Ap7fzcnGvL-362">
